---
import SectionHeading from '../ui/SectionHeading.astro';
import { profile } from '../../data/profile';

const { education } = profile;
---

<section id="education" class="relative">
  <div class="section-container">
    <SectionHeading title="Education" />

    <div class="max-w-2xl mx-auto">
      <div class="card" data-animate="fade-up">
        <div class="flex items-start gap-4 mb-6">
          <div class="w-14 h-14 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center shrink-0">
            <svg
              class="w-7 h-7 text-indigo-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"
              />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold text-white">{education.degree}</h3>
            <p class="text-indigo-400 font-medium">{education.university}</p>
            <p class="text-sm text-slate-400">{education.years}</p>
          </div>
        </div>

        <!-- Key subjects -->
        <div class="mb-6">
          <h4 class="text-sm font-semibold text-slate-300 mb-3 uppercase tracking-wider">Key Subjects</h4>
          <div class="flex flex-wrap gap-2">
            {
              education.subjects.map((subject) => (
                <span class="skill-tag text-xs">{subject}</span>
              ))
            }
          </div>
        </div>

        <!-- Awards -->
        <div>
          <h4 class="text-sm font-semibold text-slate-300 mb-3 uppercase tracking-wider">Awards</h4>
          <div class="space-y-2">
            {
              education.awards.map((award) => (
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-lg bg-amber-500/10 border border-amber-500/20 flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                    </svg>
                  </div>
                  <span class="text-slate-300 text-sm">{award}</span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
