---
import { profile, coreStrengths } from '../../data/profile';
import SectionHeading from '../ui/SectionHeading.astro';

const icons: Record<string, string> = {
  blueprint: 'M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2',
  lightning: 'M13 10V3L4 14h7v7l9-11h-7z',
  rocket: 'M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.63 8.37m5.96 6l-3.54 3.54-5.73-5.73L9.86 8.64m5.73 5.73l-5.73 5.73M4.27 19.73l5.73-5.73',
  target: 'M12 8V4l8 8-8 8v-4H4V8h8z',
  globe: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9',
};
---

<section id="about" class="relative">
  <div class="section-container">
    <SectionHeading title="About" subtitle="Focused on delivery — from concept to production." />

    <div class="max-w-3xl mx-auto mb-16">
      <p class="text-lg text-slate-300 leading-relaxed text-center" data-animate="fade-up">
        {profile.summary}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
      {
        coreStrengths.map((strength, i) => (
          <div
            class="card group text-center"
            data-animate="fade-up"
            style={`animation-delay: ${i * 100}ms`}
          >
            <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center group-hover:bg-indigo-500/20 transition-colors">
              <svg
                class="w-6 h-6 text-indigo-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d={icons[strength.icon]}
                />
              </svg>
            </div>
            <h3 class="font-semibold text-white mb-2 text-sm">{strength.title}</h3>
            <p class="text-slate-400 text-xs leading-relaxed">{strength.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
