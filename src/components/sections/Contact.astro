---
import { profile } from '../../data/profile';

const contactMethods = [
  {
    label: 'Email',
    value: profile.email,
    href: `mailto:${profile.email}`,
    icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    color: '#6366f1',
  },
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/r-keshav',
    href: profile.linkedin,
    icon: 'M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z M4 6a2 2 0 100-4 2 2 0 000 4z',
    color: '#0077b5',
    external: true,
  },
  {
    label: 'GitHub',
    value: 'github.com/Keshav-Rana',
    href: profile.github,
    icon: 'M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z',
    color: '#ffffff',
    external: true,
    filled: true,
  },
];
---

<section id="contact" class="relative">
  <div class="section-container">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4">
        <span class="gradient-text">Let's Build Something Together</span>
      </h2>
      <p class="text-slate-400 text-lg">
        I'm always open to discussing new opportunities, interesting projects, or just having a chat about technology.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl mx-auto">
      {
        contactMethods.map((method, i) => (
          <a
            href={method.href}
            target={method.external ? '_blank' : undefined}
            rel={method.external ? 'noopener noreferrer' : undefined}
            class="card group flex items-center gap-4"
            data-animate="fade-up"
            style={`animation-delay: ${i * 100}ms`}
          >
            <div
              class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0 transition-transform duration-300 group-hover:scale-110"
              style={`background-color: ${method.color}15; border: 1px solid ${method.color}30`}
            >
              <svg
                class="w-5 h-5"
                fill={method.filled ? method.color : 'none'}
                stroke={method.filled ? 'none' : method.color}
                viewBox="0 0 24 24"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d={method.icon}
                />
              </svg>
            </div>
            <div>
              <p class="text-xs text-slate-500 uppercase tracking-wider">{method.label}</p>
              <p class="text-sm text-slate-300 group-hover:text-white transition-colors">{method.value}</p>
            </div>
            {method.external && (
              <svg class="w-4 h-4 text-slate-500 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            )}
          </a>
        ))
      }
    </div>
  </div>
</section>
